{
  "permissions": {
    "allow": [
      "WebFetch(domain:app.notion.com)",
      "PowerShell(New-Item *)",
      "PowerShell(claude mcp *)",
      "Bash(claude mcp *)",
      "PowerShell(git *)",
      "Bash(git *)",
      "mcp__github__get_file_contents",
      "Bash(mv \"D:/0.vmd ops/guides/2026/6p/6P 고양스타필드\" \"D:/0.vmd ops/rounding/2026-06/\")",
      "Bash(mv \"D:/0.vmd ops/guides/2026/6p/6P 수원스타필드\" \"D:/0.vmd ops/rounding/2026-06/\")",
      "Bash(mv \"D:/0.vmd ops/guides/2026/6p/6P 용산아이파크몰\" \"D:/0.vmd ops/rounding/2026-06/\")",
      "Bash(mkdir -p \"D:/0.vmd ops/rounding/2026-06/6P 고양스타필드\")",
      "Bash(mv \"D:/0.vmd ops/rounding/2026-06/KakaoTalk_\"* \"D:/0.vmd ops/rounding/2026-06/6P 고양스타필드/\")"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Read",
        "hooks": [
          {
            "type": "command",
            "command": "python \"D:/0.vmd ops/scripts/block_binary_reads.py\""
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "python \"D:/0.vmd ops/scripts/check_size.py\""
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "powershell -ExecutionPolicy Bypass -WindowStyle Hidden -File \"D:\\0.vmd ops\\scripts\\vmd-stop-hook.ps1\"",
            "statusMessage": "memory 백업 + 완료 항목 정리 + 정합성 감지 중..."
          }
        ]
      }
    ]
  }
}
